# ─── EmailJS Config ───────────────────────────────────────────────
# Get these values from https://www.emailjs.com/
# Steps:
#  1. Sign up at emailjs.com (free)
#  2. Add Service → Gmail → connect shyam030904@gmail.com
#  3. Create Template 1 ("Incoming Message") with variables: {{from_name}}, {{from_email}}, {{message}}
#     → This email is sent TO you whenever someone fills the contact form
#  4. Create Template 2 ("Auto-Reply") with variables: {{to_name}}, {{to_email}}, {{from_name}}, {{message}}
#     → This email is sent TO the visitor to confirm you received their message
#     → IMPORTANT: In the "To Email" field of Template 2, put {{to_email}}
#  5. Copy Service ID, both Template IDs, and Public Key below

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_incoming_template_id
VITE_EMAILJS_AUTO_REPLY_TEMPLATE_ID=your_auto_reply_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
